# Copy this file to `.env` and fill in your real values. `.env` is git-ignored.
# Get a key from https://dashboard.api-football.com/ (free tier = 100 requests/day).

# --- API-Football (direct api-sports.io product) ---
APIFOOTBALL_KEY=your_api_key_here
APIFOOTBALL_BASE_URL=https://v3.football.api-sports.io

# --- Database ---
# Default is a local SQLite file; swap for a Postgres URL later without code changes.
ACCUBET_DATABASE_URL=sqlite:///data/accubet.db

# --- Logging ---
ACCUBET_LOG_LEVEL=INFO
